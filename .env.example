# Supabase (veritabanı + auth — kalır)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Depolama: supabase (varsayılan, 1 GB limit) | r2 (Cloudflare, ucuz/sınırsız ölçek)
VITE_STORAGE_PROVIDER=supabase
# R2 public bucket URL (ör. https://pub-xxxxx.r2.dev veya custom domain)
# VITE_R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# --- Vercel sunucu ortamı (R2 için, gizli tutun) ---
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=catoweeding-media

# ═══════════════════════════════════════════════════════════════
# ÜCRETSİZ PAKET (aylık ~0 TL)
# Vercel Hobby + Supabase Free + Cloudflare R2 Free
# ═══════════════════════════════════════════════════════════════
#
# Google Photos / iCloud: misafirlerin anonim yüklemesi için API yok.
# Kendi albümünüze bağlanamazsınız — sadece kendi hesabınızdaki fotoğraflar.
#
# Önerilen ücretsiz depolama: Cloudflare R2 (ayda ~10 GB bedava).
# Sıkıştırma ile 1 düğün ≈ 300–800 MB → birkaç etkinlik R2 free'a sığar.
#
# Kurulum:
# 1) cloudflare.com → R2 → bucket + public URL + CORS
# 2) Vercel env: VITE_STORAGE_PROVIDER=r2 + R2_* değişkenleri
# 3) Supabase Storage'ı medya için kullanmayın (sadece DB)
#
# Supabase 1 GB ile idare (küçük etkinlikler):
# VITE_STORAGE_PROVIDER=supabase
# VITE_FREE_STORAGE_MODE=true

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# supabase = 1 GB limit | r2 = ücretsiz paket için önerilen
VITE_STORAGE_PROVIDER=r2
VITE_FREE_STORAGE_MODE=true
VITE_R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# Vercel sunucu (gizli — sadece R2 için)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=catoweeding-media
